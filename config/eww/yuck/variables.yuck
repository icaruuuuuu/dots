;; ~/.config/eww/yuck/variables.yuck

(defpoll time :interval "1s" "date '+%H : %M'")

(defpoll hour :interval "1s" "date '+%H'")
(defpoll minute :interval "1s" "date '+%M'")

(defvar focused_window "No focused window")

(deflisten active_workspace :initial "1" "scripts/get-workspace")

(deflisten slider_data :initial '{"volume": 0, "brightness": 0}' "scripts/sliders")


